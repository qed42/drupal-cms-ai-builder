    "description": "Combined container and grid layout component with 10 column split options and 3 slots.",
    "group": "Layout",
    "category": "layout",
    "props": [
      {
        "name": "columns",
        "type": "string",
        "required": true,
        "title": "Columns",
        "description": "Column split layout.",
        "enum": [
          "100",
          "50-50",
          "33-33-33",
          "75-25",
          "25-75",
          "67-33",
          "33-67",
          "50-25-25",
          "25-25-50",
          "25-25-25-25"
        ],
        "default": "100",
        "examples": ["100"]
      },
      {
        "name": "width",
        "type": "string",
        "required": false,
        "title": "Width",
        "description": "Container width constraint.",
        "enum": ["boxed", "full", "narrow"],
        "default": "boxed",
        "examples": ["boxed"]
      },
      {
        "name": "background_color",
        "type": "string",
        "required": false,
        "title": "Background Color",
        "description": "Section background color using design token names.",
        "enum": [
          "transparent",
          "background",
          "primary",
          "secondary",
          "accent",
          "muted"
        ],
        "default": "transparent",
        "examples": ["transparent"]
      },
      {
        "name": "padding_block_start",
        "type": "string",
        "required": false,
        "title": "Padding Block Start",
        "description": "Top padding.",
        "enum": ["none", "sm", "md", "lg", "xl", "2xl"],
        "default": "lg",
        "examples": ["lg"]
      },
      {
        "name": "padding_block_end",
        "type": "string",
        "required": false,
        "title": "Padding Block End",
        "description": "Bottom padding.",
        "enum": ["none", "sm", "md", "lg", "xl", "2xl"],
        "default": "lg",
        "examples": ["lg"]
      },
      {
        "name": "margin_block_start",
        "type": "string",
        "required": false,
        "title": "Margin Block Start",
        "description": "Top margin.",
        "enum": ["none", "sm", "md", "lg", "xl", "2xl"],
        "default": "none",
        "examples": ["none"]
      },
      {
        "name": "margin_block_end",
        "type": "string",
        "required": false,
        "title": "Margin Block End",
        "description": "Bottom margin.",
        "enum": ["none", "sm", "md", "lg", "xl", "2xl"],
        "default": "none",
        "examples": ["none"]
      }
