[
  {
    "id": "mercury:section",
    "name": "Section",
    "description": "Combined container and grid layout component with column split options and 3 slots.",
    "group": "Layout",
    "category": "layout",
    "props": [
      {
        "name": "width",
        "type": "string",
        "required": true,
        "title": "Section width",
        "enum": ["100%", "90%", "80%", "75%", "50%"],
        "default": "100%",
        "examples": ["100%"]
      },
      {
        "name": "columns",
        "type": "string",
        "required": true,
        "title": "Grid layout",
        "description": "Layout selected applies on desktop and tablet.",
        "enum": [
          "100",
          "50-50",
          "33-33-33",
          "75-25",
          "25-75",
          "67-33",
          "33-67",
          "50-25-25",
          "25-25-50",
          "25-25-25-25"
        ],
        "default": "50-50",
        "examples": ["50-50"]
      },
      {
        "name": "views_columns",
        "type": "string",
        "required": false,
        "title": "Views grid",
        "description": "If you are using a view in this section, select the grid layout.",
        "enum": ["50-50", "33-33-33", "25-25-25-25"]
      },
      {
        "name": "mobile_columns",
        "type": "string",
        "required": true,
        "title": "Columns on mobile",
        "enum": ["1", "2", "3"],
        "examples": ["1"]
      },
      {
        "name": "margin_block_start",
        "type": "string",
        "required": true,
        "title": "Margin top",
        "enum": ["0", "8", "20", "32", "48", "64", "96", "128"],
        "examples": ["48"]
      },
      {
        "name": "margin_block_end",
        "type": "string",
        "required": true,
        "title": "Margin bottom",
        "enum": ["0", "8", "20", "32", "48", "64", "96", "128"],
        "examples": ["48"]
      },
      {
        "name": "padding_block_start",
        "type": "string",
        "required": true,
        "title": "Padding top",
        "enum": ["0", "16", "32", "64"],
        "examples": ["0"]
      },
      {
        "name": "padding_block_end",
        "type": "string",
        "required": true,
        "title": "Padding bottom",
        "enum": ["0", "16", "32", "64"],
        "examples": ["0"]
      },
      {
        "name": "background_color",
        "type": "string",
        "required": false,
        "title": "Background color",
        "enum": ["primary", "secondary", "accent", "muted"]
      },
      {
        "name": "background_media",
        "type": "object",
        "required": false,
        "title": "Background image",
        "$ref": "json-schema-definitions://canvas.module/image"
      },
      {
        "name": "section_header",
        "type": "boolean",
        "required": false,
        "title": "Show header region",
        "default": true,
        "examples": [true]
      },
      {
        "name": "section_footer",
        "type": "boolean",
        "required": false,
        "title": "Show footer region",
        "default": true,
        "examples": [true]
      }
