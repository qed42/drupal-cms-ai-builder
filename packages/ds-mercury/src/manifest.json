    "slots": [
      { "name": "header_slot", "description": "Section header area, typically for headings." },
      { "name": "main_slot", "description": "Primary content area for child components." },
      { "name": "footer_slot", "description": "Section footer area, typically for CTAs." }
    ]
  },
