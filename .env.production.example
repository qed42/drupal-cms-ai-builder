# =============================================================================
# Production Environment Variables for AI Site Builder
# Copy to .env.production and fill in real values before deploying.
# =============================================================================

# --- PostgreSQL (Platform Database) ---
PG_PASSWORD=change-me-strong-password

# --- MariaDB (Drupal Database) ---
MARIADB_ROOT_PASSWORD=change-me-strong-password

# --- Next.js / NextAuth ---
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
JWT_SHARED_SECRET=generate-with-openssl-rand-base64-32
PROVISION_CALLBACK_KEY=generate-with-openssl-rand-base64-32

# --- AI / Anthropic ---
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Caddy / GoDaddy DNS-01 ---
GODADDY_API_KEY=your-godaddy-api-key
GODADDY_API_SECRET=your-godaddy-api-secret
