# Database
DATABASE_URL="postgresql://space:space_dev_password@localhost:5433/space_platform"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-change-in-production-32chars!"

# AI Provider Configuration
# Supported: "openai" (default), "anthropic"
AI_PROVIDER=openai
# Global model override (optional — each provider has its own default)
# AI_MODEL=gpt-4o-mini
# Per-phase model overrides (optional)
# AI_MODEL_RESEARCH=gpt-4o
# AI_MODEL_PLAN=gpt-4o-mini
# AI_MODEL_GENERATE=gpt-4o-mini

# OpenAI Key (required if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here

# Anthropic Key (required if AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# JWT shared secret for Drupal auto-login tokens (must match Drupal settings.php)
JWT_SHARED_SECRET="dev-jwt-secret-change-in-production"

# Provisioning callback authentication key (validates step-11 callback)
PROVISION_CALLBACK_KEY="dev-callback-key-change-in-production"

# Database credentials for provisioning engine (DDEV defaults shown)
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_USER="db"
DB_PASSWORD="db"
