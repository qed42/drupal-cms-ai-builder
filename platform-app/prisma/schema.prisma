generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- NextAuth tables ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// --- Application tables ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  sites              Site[]
  onboardingSessions OnboardingSession[]

  @@map("users")
}

model Site {
  id             String   @id @default(cuid())
  userId         String
  name           String?
  subdomain      String?  @unique
  status         String   @default("onboarding")
  drupalUrl      String?
  pipelinePhase  String?
  pipelineError  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  blueprint       Blueprint?
  subscription    Subscription?
  researchBriefs  ResearchBrief[]
  contentPlans    ContentPlan[]

  @@map("sites")
}

model OnboardingSession {
  id               String   @id @default(cuid())
  userId           String
  siteId           String?
  step             String   @default("start")
  data             Json     @default("{}")
  completed        Boolean  @default(false)
  researchPreview  Json?    @map("research_preview")
  previewInputHash String?  @map("preview_input_hash")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_sessions")
}

model Blueprint {
  id              String   @id @default(cuid())
  siteId          String   @unique
  payload         Json     @default("{}")
  originalPayload Json?
  status          String   @default("draft")
  generationStep  String   @default("pending")
  generationError String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  site     Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  versions BlueprintVersion[]

  @@map("blueprints")
}

model ResearchBrief {
  id         String   @id @default(cuid())
  siteId     String
  version    Int      @default(1)
  content    Json
  model      String
  provider   String
  durationMs Int?
  createdAt  DateTime @default(now())

  site         Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  contentPlans ContentPlan[]

  @@unique([siteId, version])
  @@map("research_briefs")
}

model ContentPlan {
  id              String   @id @default(cuid())
  siteId          String
  researchBriefId String
  version         Int      @default(1)
  content         Json
  model           String
  provider        String
  durationMs      Int?
  createdAt       DateTime @default(now())

  site          Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  researchBrief ResearchBrief @relation(fields: [researchBriefId], references: [id], onDelete: Cascade)

  @@unique([siteId, version])
  @@map("content_plans")
}

model BlueprintVersion {
  id          String   @id @default(cuid())
  blueprintId String
  version     Int      @default(1)
  label       String?
  payload     Json
  createdAt   DateTime @default(now())

  blueprint Blueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)

  @@unique([blueprintId, version])
  @@map("blueprint_versions")
}

model Subscription {
  id          String    @id @default(cuid())
  siteId      String    @unique
  plan        String    @default("trial")
  status      String    @default("active")
  trialEndsAt DateTime?
  stripeId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
