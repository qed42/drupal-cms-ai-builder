FROM node:22-alpine

RUN apk add --no-cache docker-cli

WORKDIR /workspace

# Copy root workspace config and package directories
COPY package.json ./
COPY packages/ ./packages/
COPY platform-app/package*.json ./platform-app/

# Install all workspace dependencies
RUN npm install

WORKDIR /workspace/platform-app

COPY platform-app/prisma ./prisma
RUN npx prisma generate

COPY platform-app/ .

EXPOSE 3000

# Auto-run Prisma migrations and start dev server
CMD ["sh", "-c", "npx prisma migrate deploy && npx prisma generate && npm run dev"]
