<?php

/**
 * @file
 * Primary module hooks for AI Site Builder module.
 */

declare(strict_types=1);

/**
 * Implements hook_toolbar_alter().
 *
 * Hides admin toolbar items for site_owner role, keeping only content
 * listing and Canvas editor access.
 */
function ai_site_builder_toolbar_alter(array &$items): void {
  $current_user = \Drupal::currentUser();

  if (!in_array('site_owner', $current_user->getRoles(), TRUE)) {
    return;
  }

  // Hide admin-focused toolbar items for site owners.
  $hidden_items = [
    'administration',
    'shortcuts',
    'contextual',
    'tour',
  ];

  foreach ($hidden_items as $item) {
    if (isset($items[$item])) {
      $items[$item]['#access'] = FALSE;
    }
  }
}

